# MistVil — Apache / Hostinger configuration

# Serve the MistVil app first even if WordPress files (index.php) exist in
# the same folder — the app takes over the (sub)domain it is uploaded to.
DirectoryIndex index.html index.php

RewriteEngine On

# Force HTTPS: login hashing uses the browser WebCrypto API, which is only
# available on secure origins — and visitors should never send passwords or
# read content over plain HTTP anyway. (Hostinger provides free SSL.)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: send www.mistvil.online to the bare mistvil.online so every
# visitor lands on ONE origin. Accounts, bookmarks, and the reading history
# live in per-origin browser storage — splitting visitors between www and the
# bare domain would give them two separate "sites".
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Route the shared-database API to the PHP handler so the site works without a
# running Node.js server. The client keeps calling /api/db.
RewriteRule ^api/db/?$ api/db.php [L]

# Route the cross-device accounts API to its PHP handler. The client calls
# /api/auth for register/login/profile-update.
RewriteRule ^api/auth/?$ api/auth.php [L]

# Route the dynamic per-novel sitemap for search engines.
RewriteRule ^api/sitemap\.php$ api/sitemap.php [L]

# Single-page app fallback: serve index.html for any path that is not a real
# file or directory, so deep links and refreshes don't 404.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Never expose the shared data file or the accounts file directly to the
# public — accounts (emails + password hashes) are read only by auth.php.
<Files "mistvil_db.json">
  Require all denied
</Files>
<Files "mistvil_users.json">
  Require all denied
</Files>

# Sensible caching for built assets (they are content-hashed by Vite).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|svg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html must always be re-fetched so visitors get the LATEST build
  # (which references the newest hashed JS/CSS) immediately after every deploy —
  # never a stale cached shell.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  # The shared APIs are dynamic — never let a proxy/CDN cache their responses
  # (the app does its own ETag-based conditional polling).
  <FilesMatch "^(db|auth|sitemap)\.php$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
